# Copie para `.env` na raiz do repo (ao lado de docker-compose.yml).
# Não commite `.env` com segredos reais.

# --- Traefik / stack ---
# Domínio público (sem https://)
DOMAIN=guia.seudominio.com.br
# Nome do cert resolver configurado no Traefik (ex.: letsencrypt, myresolver)
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- API (também em apps/api/.env em dev) ---
# Estes valores são sobrescritos pelo docker-compose onde aplicável:
# NODE_ENV, PORT, DATABASE_URL, SWAGGER_ENABLED, CORS_ORIGINS, WEB_APP_URL, GOOGLE_CALLBACK_URL

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_SECRET=change-me-at-least-16-chars
JWT_EXPIRES_IN=1h
JWT_COOKIE_NAME=access_token
JWT_COOKIE_MAX_AGE_MS=3600000

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Opcional: deixe em branco ou omita se não usar LLM
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
